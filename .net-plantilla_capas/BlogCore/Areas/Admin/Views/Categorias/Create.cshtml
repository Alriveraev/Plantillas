@model BlogCoreSolution.Models.Categoria

@{
    ViewData["Title"] = "Crear Categoría";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Crear Categoría</h2>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3 row">
                    <label asp-for="Nombre" class="col-sm-4 col-form-label"></label>
                    <div class="col-sm-8">
                        <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre de la categoría" />
                        <span asp-validation-for="Nombre" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="Orden" class="col-sm-4 col-form-label"></label>
                    <div class="col-sm-8">
                        <input asp-for="Orden" type="number" class="form-control" placeholder="Ingrese el orden de la categoría" />
                        <span asp-validation-for="Orden" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="form-group-row">
                    <div>
                        <partial name="_VistaCrearVolver" />
                    </div>
                </div>
            </form>
            
        </div>
    </div>
</div>


@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial"/>
    }
}
                      