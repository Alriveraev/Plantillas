@model BlogCoreSolution.Models.ViewModels.ArticuloVM

@{
    ViewData["Title"] = "Crear Artículo";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Crear Artículo</h2>
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3 row">
                    <label asp-for="Articulo.Nombre" class="col-sm-4 col-form-label"></label>
                    <div class="col-sm-8">
                        <input asp-for="Articulo.Nombre" class="form-control" placeholder="Ingrese el nombre del artículo" />
                        <span asp-validation-for="Articulo.Nombre" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="mb-3 row">
                    <label asp-for="Articulo.Descripcion" class="col-sm-4 col-form-label"></label>
                    <div class="col-sm-8">
                        <input asp-for="Articulo.Descripcion" class="form-control" placeholder="Ingrese la descripción del artículo" />
                        <span asp-validation-for="Articulo.Descripcion" class="text-danger d-block mt-1"></span>
                    </div>
                </div>
                <div class="mb-3 row">
                    <label asp-for="Articulo.CategoriaId" class="col-sm-4 col-form-label"></label>
                    <div class="col-sm-8">
                        <select asp-for="Articulo.CategoriaId" class="form-control" asp-items="Model.ListaCategorias">
                            <option value="">Seleccione una categoría</option>
                        </select>
                        <span asp-validation-for="Articulo.CategoriaId" class="text-danger d-block mt-1"></span>
                    </div>
                </div>

                <div class="form-group-row">
                    <div>
                        <partial name="_VistaCrearVolver" />
                    </div>
                </div>
            </form>
            
        </div>
    </div>
</div>


@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}

                      